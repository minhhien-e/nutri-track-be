generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  male
  female
}

enum ActivityLevel {
  sedentary
  lightlyActive
  moderatelyActive
  veryActive
  extraActive
}

enum Goal {
  loseWeight
  maintainWeight
  gainWeight
}

enum UserRole {
  USER
  ADMIN
}



enum FoodSource {
  adminCatalog
  external
  custom
}

enum MealPlanDefaultScope {
  day
  week
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  passwordHash     String
  displayName      String
  role             UserRole          @default(USER)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  profile          UserProfile?
  nutritionTarget  NutritionTarget?
  dailyRecords     DailyRecord[]
  weeklyWeightLogs WeeklyWeightLog[]
  recentFoods      RecentFood[]
  customFoods      FoodItem[]        @relation("CustomFoods")
  mealPlanDefaults MealPlanDefault[]
}

model UserProfile {
  id            String        @id @default(uuid())
  userId        String        @unique
  age           Int
  gender        Gender
  heightCm      Float
  weightKg      Float
  activityLevel ActivityLevel
  goal          Goal
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NutritionTarget {
  id                        String    @id @default(uuid())
  userId                    String    @unique
  startDate                 DateTime  @default(now())
  startWeightKg             Float     @default(0)
  targetWeightKg            Float     @default(0)
  targetDate                DateTime  @default(now())
  bmr                       Float
  tdee                      Float
  estimatedTdee             Float     @default(0)
  actualTdee                Float?
  actualTdeeCalculatedAt    DateTime?
  actualTdeeWindowDays      Int?
  dailyBaseBurnKcal         Float     @default(0)
  dailyActivityBurnKcal     Float     @default(0)
  dailyTotalBurnKcal        Float     @default(0)
  dailyEnergyAdjustmentKcal Float     @default(0)
  targetCalories            Float
  proteinG                  Float
  carbsG                    Float
  fatG                      Float
  totalFatG                 Float     @default(0)
  fiberG                    Float     @default(25)
  waterMl                   Float     @default(0)
  saturatedFatLimitG        Float     @default(0)
  omega3TargetG             Float     @default(0)
  transFatLimitG            Float     @default(0)
  macroRatio                String
  calculatedAt              DateTime  @default(now())
  user                      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeeklyWeightLog {
  id           String   @id @default(uuid())
  userId       String
  weekKey      String
  measuredDate DateTime
  weightKg     Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekKey])
  @@index([weekKey])
}

model FoodItem {
  id                   String                @id @default(uuid())
  name                 String
  brandName            String?
  servingSizeG         Float
  caloriesPer100g      Float
  proteinPer100g       Float
  carbsPer100g         Float
  fatPer100g           Float
  totalFatPer100g      Float                 @default(0)
  saturatedFatPer100g  Float                 @default(0)
  omega3Per100g        Float                 @default(0)
  transFatPer100g      Float                 @default(0)
  fiberPer100g         Float                 @default(0)
  source               FoodSource
  imageAssetPath       String?
  category             String?
  displayTag           String?
  isActive             Boolean               @default(true)
  ownerUserId          String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  ownerUser            User?                 @relation("CustomFoods", fields: [ownerUserId], references: [id], onDelete: SetNull)
  mealEntries          MealEntry[]
  recentFoods          RecentFood[]
  mealPlanDefaultItems MealPlanDefaultItem[]
  foodNutrients        FoodNutrient[]

  @@index([name])
  @@index([category])
}

model DailyRecord {
  id               String      @id @default(uuid())
  userId           String
  dateKey          String
  waterMl          Float       @default(0)
  exerciseCalories Float       @default(0)
  updatedAt        DateTime    @updatedAt
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealEntries      MealEntry[]

  @@unique([userId, dateKey])
  @@index([dateKey])
}

model MealEntry {
  id            String      @id @default(uuid())
  dailyRecordId String
  foodItemId    String
  grams         Float
  calories      Float
  proteinG      Float
  carbsG        Float
  fatG          Float
  totalFatG     Float       @default(0)
  saturatedFatG Float       @default(0)
  omega3G       Float       @default(0)
  transFatG     Float       @default(0)
  fiberG        Float       @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  dailyRecord   DailyRecord @relation(fields: [dailyRecordId], references: [id], onDelete: Cascade)
  foodItem      FoodItem    @relation(fields: [foodItemId], references: [id], onDelete: Restrict)
}

model RecentFood {
  id         String   @id @default(uuid())
  userId     String
  foodItemId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodItem   FoodItem @relation(fields: [foodItemId], references: [id], onDelete: Cascade)

  @@unique([userId, foodItemId])
  @@index([userId, createdAt])
}

model MealPlanDefault {
  id        String                @id @default(uuid())
  userId    String
  name      String
  scope     MealPlanDefaultScope
  enabled   Boolean               @default(true)
  startDate DateTime
  endDate   DateTime
  dateKey   String?
  weekday   Int?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     MealPlanDefaultItem[]

  @@index([userId, enabled, scope])
  @@index([dateKey])
  @@index([weekday])
}

model MealPlanDefaultItem {
  id                String          @id @default(uuid())
  mealPlanDefaultId String
  foodItemId        String
  grams             Float
  sortOrder         Int             @default(0)
  mealPlanDefault   MealPlanDefault @relation(fields: [mealPlanDefaultId], references: [id], onDelete: Cascade)
  foodItem          FoodItem        @relation(fields: [foodItemId], references: [id], onDelete: Restrict)

  @@index([mealPlanDefaultId])
  @@index([foodItemId])
}

enum NutrientCategory {
  vitamin
  mineral
  macro
  other
}

model BodySystem {
  id          String               @id @default(uuid())
  name        String               @unique
  description String?
  nutrients   BodySystemNutrient[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model Nutrient {
  id                 String               @id @default(uuid())
  name               String               @unique
  unit               String
  category           NutrientCategory     @default(other)
  defaultDailyTarget Float                @default(0)
  bodySystems        BodySystemNutrient[]
  foodItems          FoodNutrient[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model BodySystemNutrient {
  id           String     @id @default(uuid())
  bodySystemId String
  nutrientId   String
  impactLevel  Int        @default(1)
  bodySystem   BodySystem @relation(fields: [bodySystemId], references: [id], onDelete: Cascade)
  nutrient     Nutrient   @relation(fields: [nutrientId], references: [id], onDelete: Cascade)

  @@unique([bodySystemId, nutrientId])
}

model FoodNutrient {
  id            String   @id @default(uuid())
  foodItemId    String
  nutrientId    String
  amountPer100g Float
  foodItem      FoodItem @relation(fields: [foodItemId], references: [id], onDelete: Cascade)
  nutrient      Nutrient @relation(fields: [nutrientId], references: [id], onDelete: Cascade)

  @@unique([foodItemId, nutrientId])
}
